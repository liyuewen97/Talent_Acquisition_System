generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        String       @id @default(uuid()) @db.Uuid
  code      UserRoleCode @unique
  name      String       @db.VarChar(50)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  users     User[]

  @@map("roles")
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  roleId              String               @db.Uuid
  name                String               @db.VarChar(100)
  email               String?              @unique @db.VarChar(255)
  phone               String?              @db.VarChar(50)
  passwordHash        String               @map("password_hash") @db.VarChar(255)
  status              UserStatus           @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  changeLogs          CandidateChangeLog[] @relation("ChangeLogActor")
  followUps           CandidateFollowUp[]  @relation("FollowUpUser")
  uploadedResumes     CandidateResume[]    @relation("ResumeUploader")
  ownedCandidates     Candidate[]          @relation("CandidateCreator")
  followingCandidates Candidate[]          @relation("CurrentFollowUser")
  ownedClients        Client[]             @relation("ClientOwner")
  ownedJobs           Job[]                @relation("JobOwner")
  createdTags         Tag[]                @relation("TagCreator")
  role                Role                 @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Candidate {
  id                  String                    @id @default(uuid()) @db.Uuid
  name                String                    @db.VarChar(100)
  gender              String?                   @db.VarChar(20)
  birthDate           DateTime?                 @map("birth_date") @db.Date
  phone               String?                   @db.VarChar(50)
  wechat              String?                   @db.VarChar(100)
  email               String?                   @db.VarChar(255)
  city                String?                   @db.VarChar(100)
  currentCompany      String?                   @map("current_company") @db.VarChar(255)
  currentTitle        String?                   @map("current_title") @db.VarChar(255)
  yearsOfExperience   Decimal?                  @map("years_of_experience") @db.Decimal(5, 2)
  source              String?                   @db.VarChar(100)
  status              CandidateStatus           @default(NEW)
  summary             String?
  skills              String?
  currentFollowUserId String?                   @map("current_follow_user_id") @db.Uuid
  createdBy           String                    @map("created_by") @db.Uuid
  lastFollowUpAt      DateTime?                 @map("last_follow_up_at")
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  changeLogs          CandidateChangeLog[]
  educations          CandidateEducation[]
  followUps           CandidateFollowUp[]
  resumes             CandidateResume[]
  tags                CandidateTag[]
  workExperiences     CandidateWorkExperience[]
  projects            CandidateProject[]
  creator             User                      @relation("CandidateCreator", fields: [createdBy], references: [id])
  currentFollowUser   User?                     @relation("CurrentFollowUser", fields: [currentFollowUserId], references: [id])

  @@index([name])
  @@index([phone])
  @@index([currentCompany])
  @@index([currentTitle])
  @@index([currentFollowUserId])
  @@index([lastFollowUpAt])
  @@map("candidates")
}

model CandidateEducation {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @db.Uuid
  schoolName  String    @map("school_name") @db.VarChar(255)
  degree      String    @db.VarChar(100)
  major       String?   @db.VarChar(255)
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  isTopDegree Boolean   @default(false) @map("is_top_degree")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_educations")
}

model CandidateWorkExperience {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @db.Uuid
  companyName String    @map("company_name") @db.VarChar(255)
  title       String    @db.VarChar(255)
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  description String?
  sortOrder   Int?      @map("sort_order")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_work_experiences")
}

model CandidateProject {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @db.Uuid
  projectName String    @map("project_name") @db.VarChar(255)
  role        String?   @db.VarChar(255)
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  description String?
  link        String?   @db.VarChar(500)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_projects")
}

model CandidateResume {
  id                String            @id @default(uuid()) @db.Uuid
  candidateId       String?           @map("candidate_id") @db.Uuid
  originalFileName  String            @map("original_file_name") @db.VarChar(255)
  filePath          String            @map("file_path") @db.VarChar(500)
  fileType          String            @map("file_type") @db.VarChar(50)
  extractedText     String?           @map("extracted_text")
  parserProvider    String?           @map("parser_provider") @db.VarChar(100)
  parseStatus       ResumeParseStatus @default(PENDING) @map("parse_status")
  parsedResultJson  Json?             @map("parsed_result_json")
  parserRawResponse Json?             @map("parser_raw_response")
  uploadedBy        String            @map("uploaded_by") @db.Uuid
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  candidate         Candidate?        @relation(fields: [candidateId], references: [id])
  uploader          User              @relation("ResumeUploader", fields: [uploadedBy], references: [id])

  @@index([candidateId])
  @@map("candidate_resumes")
}

model Tag {
  id         String         @id @default(uuid()) @db.Uuid
  name       String         @unique @db.VarChar(100)
  color      String?        @db.VarChar(30)
  status     String         @default("ACTIVE") @db.VarChar(30)
  createdBy  String         @map("created_by") @db.Uuid
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  candidates CandidateTag[]
  creator    User           @relation("TagCreator", fields: [createdBy], references: [id])

  @@map("tags")
}

model CandidateTag {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @db.Uuid
  tagId       String    @db.Uuid
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([candidateId, tagId])
  @@index([candidateId])
  @@index([tagId])
  @@map("candidate_tags")
}

model CandidateFollowUp {
  id             String       @id @default(uuid()) @db.Uuid
  candidateId    String       @db.Uuid
  followUpUserId String       @map("follow_up_user_id") @db.Uuid
  followUpType   FollowUpType @map("follow_up_type")
  content        String
  nextAction     String?      @map("next_action")
  nextFollowUpAt DateTime?    @map("next_follow_up_at")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  candidate      Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  followUpUser   User         @relation("FollowUpUser", fields: [followUpUserId], references: [id])

  @@index([candidateId, createdAt])
  @@index([followUpUserId])
  @@map("candidate_follow_ups")
}

model CandidateChangeLog {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @db.Uuid
  actorUserId String    @map("actor_user_id") @db.Uuid
  actionType  String    @map("action_type") @db.VarChar(50)
  fieldName   String?   @map("field_name") @db.VarChar(100)
  oldValue    String?   @map("old_value")
  newValue    String?   @map("new_value")
  metadata    Json?
  createdAt   DateTime  @default(now())
  actorUser   User      @relation("ChangeLogActor", fields: [actorUserId], references: [id])
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@index([actorUserId])
  @@map("candidate_change_logs")
}

model Client {
  id                String        @id @default(uuid()) @db.Uuid
  companyName       String        @map("company_name") @db.VarChar(255)
  industry          String?       @db.VarChar(100)
  city              String?       @db.VarChar(100)
  cooperationStatus String        @map("cooperation_status") @db.VarChar(50)
  priority          PriorityLevel @default(MEDIUM)
  ownerUserId       String        @map("owner_user_id") @db.Uuid
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  owner             User          @relation("ClientOwner", fields: [ownerUserId], references: [id])
  jobs              Job[]

  @@index([ownerUserId])
  @@map("clients")
}

model Job {
  id           String        @id @default(uuid()) @db.Uuid
  clientId     String        @db.Uuid
  title        String        @db.VarChar(255)
  city         String?       @db.VarChar(100)
  salaryRange  String?       @map("salary_range") @db.VarChar(100)
  description  String?
  requirements String?
  priority     PriorityLevel @default(MEDIUM)
  status       JobStatus     @default(OPEN)
  deadline     DateTime?     @db.Date
  ownerUserId  String        @map("owner_user_id") @db.Uuid
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner        User          @relation("JobOwner", fields: [ownerUserId], references: [id])

  @@index([clientId])
  @@index([ownerUserId])
  @@index([priority, status])
  @@map("jobs")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String   @map("entity_id") @db.Uuid
  action      String   @db.VarChar(50)
  summary     String   @db.VarChar(255)
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

enum UserRoleCode {
  ADMIN
  ASSISTANT
  INTERN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CandidateStatus {
  NEW
  FOLLOWING
  AVAILABLE
  ON_HOLD
  ARCHIVED
}

enum ResumeParseStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CONFIRMED
}

enum FollowUpType {
  INITIAL_CONTACT
  PHONE_CALL
  WECHAT
  RESUME_RECEIVED
  PRE_RECOMMENDATION
  NOT_SUITABLE
  FOLLOW_LATER
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum JobStatus {
  OPEN
  PAUSED
  CLOSED
}
